              "eslint-plugin/configs"
            ]
          },
          {
            "group": "UI Components",
            "pages": [
              "ui-components/installation",
              "ui-components/setup",
              "ui-components/theming"
            ]
          }
        ]
      },
      {
        "tab": "Rules",
        "groups": [
          {
            "group": "Options Validation",
            "pages": [
              "rules/options/action-no-invalid-options",
              "rules/options/action-no-invalid-timeout-ms",
              "rules/options/action-require-timeout-ms-comment",
              "rules/options/action-require-explicit-return-type",
              "rules/options/global-action-no-action-type",
              "rules/options/model-action-invalid-action-type",
              "rules/options/model-action-no-invalid-trigger",
              "rules/options/model-action-no-transactional-timeout-mismatch"
